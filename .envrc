# MuJoCo is vendored (gitignored) at vendor/mujoco/mujoco.framework.
#
# mujoco-rs links it dynamically (build.rs, MUJOCO_DYNAMIC_LINK_DIR branch): it
# searches this dir for a file named *exactly* `libmujoco.dylib` and emits
# `-lmujoco`. The vendored framework only ships
#   mujoco.framework/Versions/A/libmujoco.3.8.0.dylib
# so the linker can't find it by that bare name. We expose a `libmujoco.dylib`
# link shim next to the framework purely so the linker can resolve it.
#
# At runtime the shim is NOT on the load path: the dylib's install name
# (@rpath/mujoco.framework/Versions/A/libmujoco.3.8.0.dylib) resolves via the
# rpath baked in .cargo/config.toml, straight to the real framework file. So
# compile and runtime end up at the same physical dylib.
#
# Recreated here so the shim self-heals whenever vendor/mujoco is re-populated.
export MUJOCO_DYNAMIC_LINK_DIR="$PWD/vendor/mujoco"

_mj_real="$MUJOCO_DYNAMIC_LINK_DIR/mujoco.framework/Versions/A/libmujoco.3.8.0.dylib"
_mj_shim="$MUJOCO_DYNAMIC_LINK_DIR/libmujoco.dylib"
if [ -e "$_mj_real" ] && [ ! -e "$_mj_shim" ]; then
    ln -s mujoco.framework/Versions/A/libmujoco.3.8.0.dylib "$_mj_shim"
fi
unset _mj_real _mj_shim
